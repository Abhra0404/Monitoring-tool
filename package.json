{
  "name": "theoria-cli",
  "version": "1.0.2",
  "description": "Self-hosted system monitoring — one command, full dashboard. npx theoria-cli to start.",
  "bin": {
    "theoria-cli": "./bin/theoria.js"
  },
  "files": [
    "bin/",
    "server/dist/",
    "server/package.json",
    "server/package-lock.json",
    "server/drizzle.config.ts",
    "server/scripts/",
    "client/build/",
    "agent/cmd/",
    "agent/internal/",
    "agent/go.mod",
    "agent/theoria-agent",
    "agent/bin/"
  ],
  "scripts": {
    "start": "node bin/theoria.js",
    "postinstall": "cd server && npm ci --omit=dev --legacy-peer-deps --ignore-scripts || true",
    "build:server": "cd server && npm install --legacy-peer-deps && npm run build",
    "build:client": "cd client && npm install --legacy-peer-deps && VITE_API_URL= npm run build",
    "build": "npm run build:server && npm run build:client",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "monitoring",
    "dashboard",
    "devops",
    "self-hosted",
    "server-monitoring",
    "cli",
    "grafana-alternative",
    "system-monitor",
    "real-time"
  ],
  "author": "Abhra0404",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abhra0404/Monitoring-tool.git"
  },
  "homepage": "https://github.com/Abhra0404/Monitoring-tool#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.7.7"
  }
}
