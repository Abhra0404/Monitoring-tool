{
  "name": "monitorx",
  "version": "1.0.0",
  "description": "Self-hosted system monitoring — one command, full dashboard",
  "bin": {
    "monitorx": "./bin/monitorx.js"
  },
  "scripts": {
    "start": "node bin/monitorx.js",
    "dev": "concurrently --names \"SERVER,CLIENT\" --prefix-colors \"blue,yellow\" \"npm start --prefix server\" \"npm start --prefix client\"",
    "server": "npm start --prefix server",
    "agent": "npm start --prefix agent",
    "client": "npm start --prefix client",
    "build": "npm run build --prefix client"
  },
  "keywords": ["monitoring", "dashboard", "devops", "system-monitor", "self-hosted"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
