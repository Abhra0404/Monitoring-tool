{
  "name": "theoria-plugin-nginx",
  "displayName": "Nginx",
  "version": "1.0.0",
  "type": "server-check",
  "entry": "index.js",
  "description": "Scrapes nginx's stub_status endpoint for connection counts and request rates.",
  "author": "Theoria",
  "icon": "globe",
  "intervalSeconds": 30,
  "timeoutMs": 5000,
  "metrics": [
    { "name": "active_connections", "description": "Current active client connections" },
    { "name": "reading", "description": "Connections reading request headers" },
    { "name": "writing", "description": "Connections writing response" },
    { "name": "waiting", "description": "Idle keep-alive connections" },
    { "name": "accepts_total", "description": "Total accepted connections since start" },
    { "name": "handled_total", "description": "Total handled connections" },
    { "name": "requests_total", "description": "Total client requests" }
  ],
  "configSchema": {
    "type": "object",
    "required": ["url"],
    "properties": {
      "url": {
        "type": "string",
        "format": "url",
        "default": "http://127.0.0.1/nginx_status",
        "description": "Full URL of the stub_status endpoint"
      },
      "insecure": { "type": "boolean", "default": false, "description": "Skip TLS verification" }
    }
  }
}
